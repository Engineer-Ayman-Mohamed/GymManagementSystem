@model MembershipDto

@{
    ViewData["Title"] = "Membership Details";
    var now = DateTime.Now;
    var isValid = Model.StartDate <= now && Model.EndDate >= now;
    var statusClass = isValid ? "active" : (Model.EndDate < now ? "inactive" : "pending");
    var statusLabel = isValid ? "Active" : (Model.EndDate < now ? "Expired" : "Upcoming");
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-id-card me-2"></i>Membership Details</h2>
        <p class="subtitle">Membership information for @Model.MemberName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="profile-header">
            <div class="profile-avatar-lg">
                <i class="fas fa-id-card"></i>
            </div>
            <h3>@Model.MemberName</h3>
            <p><i class="fas fa-envelope me-1"></i>@Model.MemberEmail</p>
            <span class="status-badge @statusClass">
                <span class="status-dot"></span>
                @statusLabel
            </span>
        </div>
    </div>

    <div class="col-lg-8 d-flex flex-column gap-3">
        <div class="card detail-group">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Membership Information
            </div>
            <div class="card-body">
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-user"></i> Member</span>
                    <span class="detail-value">@Model.MemberName</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-envelope"></i> Member Email</span>
                    <span class="detail-value">@Model.MemberEmail</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-clipboard-list"></i> Plan</span>
                    <span class="detail-value">@Model.PlanName</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-dollar-sign"></i> Plan Price</span>
                    <span class="detail-value text-success fw-bold">$@Model.PlanPrice.ToString("F2")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-calendar"></i> Start Date</span>
                    <span class="detail-value">@Model.StartDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-calendar-check"></i> End Date</span>
                    <span class="detail-value">@Model.EndDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-check-circle"></i> Status</span>
                    <span class="detail-value">
                        <span class="status-badge @statusClass">
                            <span class="status-dot"></span>
                            @statusLabel
                        </span>
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-clock"></i> Created At</span>
                    <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
        </div>
    </div>
</div>
