@model MembershipDto

@{
    ViewData["Title"] = "Delete Membership";
}

<div class="delete-card">
    <div class="delete-icon">
        <i class="fas fa-exclamation-triangle"></i>
    </div>
    <h3>Delete Membership</h3>
    <p class="text-muted mb-2">
        Are you sure you want to delete this membership for <strong>@Model.MemberName</strong>?
    </p>
    <p class="text-muted mb-4 small">
        <i class="fas fa-info-circle me-1"></i>
        This action will soft-delete the membership. Historical data will be preserved.
    </p>

    <div class="detail-items mb-4">
        <div class="detail-item">
            <span class="detail-label">Member</span>
            <span class="detail-value">@Model.MemberName</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Plan</span>
            <span class="detail-value">@Model.PlanName</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Period</span>
            <span class="detail-value">@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</span>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="d-flex gap-2 justify-content-center">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Delete
            </button>
        </div>
    </form>
</div>
