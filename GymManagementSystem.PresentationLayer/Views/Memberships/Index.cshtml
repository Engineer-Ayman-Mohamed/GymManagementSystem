@model IReadOnlyList<MembershipDto>

@{
    ViewData["Title"] = "Memberships";
    var now = DateTime.Now;
    var activeNow = Model.Count(m => m.StartDate <= now && m.EndDate >= now);
    var endingSoon = Model.Count(m => m.EndDate >= now && m.EndDate <= now.AddDays(30));
    var uniquePlans = Model.Select(m => m.PlanName).Distinct().Count();
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-id-card me-2"></i>Memberships</h2>
        <p class="subtitle">Manage all member memberships</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <div class="btn-group" role="group">
            <a asp-action="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Membership
        </a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-id-card"></i></div>
        <div class="stat-label">Total Memberships</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-list"></i> All records</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div class="stat-label">Active Now</div>
        <div class="stat-value">@activeNow</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Currently valid</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-clock"></i></div>
        <div class="stat-label">Ending Soon</div>
        <div class="stat-value">@endingSoon</div>
        <div class="stat-trend"><i class="fas fa-exclamation-triangle"></i> Within 30 days</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-clipboard-list"></i></div>
        <div class="stat-label">Active Plans</div>
        <div class="stat-value">@uniquePlans</div>
        <div class="stat-trend"><i class="fas fa-layer-group"></i> Plan types</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fas fa-list me-2"></i>All Memberships</span>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm" role="group">
                <a asp-action="ExportExcel" class="btn btn-outline-success" title="Export to Excel">
                    <i class="fas fa-file-excel"></i>
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-danger" title="Export to PDF">
                    <i class="fas fa-file-pdf"></i>
                </a>
            </div>
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" class="form-control form-control-sm" id="membershipSearch" placeholder="Search memberships..." style="width: 180px;">
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0" id="membershipsTable">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Plan</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="fas fa-id-card"></i>
                                    <h4>No memberships yet</h4>
                                    <p>Get started by creating your first membership.</p>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add First Membership
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var membership = Model[i];
                            var isValid = membership.StartDate <= now && membership.EndDate >= now;
                            var statusClass = isValid ? "active" : (membership.EndDate < now ? "inactive" : "pending");
                            var statusLabel = isValid ? "Active" : (membership.EndDate < now ? "Expired" : "Upcoming");
                            <tr class="row-striped" style="animation: fadeInUp 0.4s ease-out @(i * 0.05)s both;">
                                <td>
                                    <div class="member-cell">
                                        <div class="member-info">
                                            <div class="member-name">@membership.MemberName</div>
                                            <div class="member-email">@membership.MemberEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="status-badge active"><span class="status-dot"></span>@membership.PlanName</span></td>
                                <td>@membership.StartDate.ToString("MMM dd, yyyy")</td>
                                <td>@membership.EndDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot"></span>
                                        @statusLabel
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@membership.Id" class="btn btn-outline-primary btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@membership.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@membership.Id" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $('#membershipSearch').on('keyup', function() {
                const value = this.value.toLowerCase();
                $('#membershipsTable tbody tr').each(function() {
                    const row = $(this);
                    if (row.find('.empty-state').length) return;
                    const text = row.text().toLowerCase();
                    row.toggle(text.includes(value));
                });
            });
        });
    </script>
}
