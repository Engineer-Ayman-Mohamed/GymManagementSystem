@model CreateMembershipRequest

@{
    ViewData["Title"] = "Add Membership";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-plus-circle me-2"></i>Add New Membership</h2>
        <p class="subtitle">Assign a membership plan to a member</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<form asp-action="Create" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 10px; border-left: 4px solid var(--danger);">
            <i class="fas fa-exclamation-circle" style="font-size: 1.3rem;"></i>
            <div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="small">@error.ErrorMessage</div>
                }
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card form-section">
                <div class="card-header">
                    <i class="fas fa-id-card me-2"></i>Membership Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="MemberId" class="form-label">Member ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input asp-for="MemberId" class="form-control" type="number" min="1" placeholder="Enter member ID" required>
                            </div>
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlanId" class="form-label">Plan ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-clipboard-list"></i></span>
                                <input asp-for="PlanId" class="form-control" type="number" min="1" placeholder="Enter plan ID" required>
                            </div>
                            <span asp-validation-for="PlanId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                <input asp-for="StartDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                            </div>
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-check"></i></span>
                                <input asp-for="EndDate" class="form-control" type="date" required>
                            </div>
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card form-section">
                <div class="card-body text-center">
                    <i class="fas fa-dumbbell" style="font-size: 2rem; color: var(--primary); opacity: 0.5; margin-bottom: 8px;"></i>
                    <p class="small text-muted mb-0">Assign a plan to a member!</p>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 justify-content-end form-section">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
        <button type="submit" class="btn btn-success">
            <i class="fas fa-check"></i> Create Membership
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
