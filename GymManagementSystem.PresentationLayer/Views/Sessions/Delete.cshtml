@model SessionDto

@{
    ViewData["Title"] = "Delete Session";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-calendar-minus me-2"></i>Delete Session</h2>
        <p class="subtitle">Remove a session from the system</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card delete-card">
            <div class="delete-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>Are you sure?</h3>
            <p>
                You are about to delete session
                <span class="member-name-highlight">@Model.Description</span>.
                This action cannot be undone.
            </p>

            <div class="card mb-4" style="background: var(--gray-50);">
                <div class="card-body text-start">
                    <div class="fw-bold mb-2">@Model.Description</div>
                    <div class="small text-muted">
                        <i class="fas fa-user-tie me-1"></i>@Model.TrainerName |
                        <i class="fas fa-tag me-1 ms-2"></i>@Model.CategoryName |
                        <i class="fas fa-users me-1 ms-2"></i>Capacity: @Model.Capacity
                    </div>
                    <div class="small text-muted mt-1">
                        <i class="fas fa-calendar me-1"></i>@Model.StartDate.ToString("MMM dd, yyyy HH:mm") -
                        @Model.EndDate.ToString("MMM dd, yyyy HH:mm")
                    </div>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="fas fa-trash"></i> Delete Session
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
