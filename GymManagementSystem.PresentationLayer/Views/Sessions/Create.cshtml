@model CreateSessionRequest

@{
    ViewData["Title"] = "Add Session";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-calendar-plus me-2"></i>Add New Session</h2>
        <p class="subtitle">Create a new gym session</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<form asp-action="Create" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-1"></i>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="small">@error.ErrorMessage</div>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card form-section">
                <div class="card-header">
                    <i class="fas fa-info-circle me-2"></i>Session Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                <input asp-for="Description" class="form-control" placeholder="e.g. Morning Yoga Flow" required>
                            </div>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Capacity" class="form-label">Capacity</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-users"></i></span>
                                <input asp-for="Capacity" class="form-control" type="number" min="1" placeholder="30" required>
                            </div>
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TrainerId" class="form-label">Trainer ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user-tie"></i></span>
                                <input asp-for="TrainerId" class="form-control" type="number" placeholder="1" required>
                            </div>
                            <span asp-validation-for="TrainerId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                <input asp-for="CategoryId" class="form-control" type="number" placeholder="1" required>
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Start Date & Time</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-play"></i></span>
                                <input asp-for="StartDate" class="form-control" type="datetime-local" required>
                            </div>
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">End Date & Time</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-stop"></i></span>
                                <input asp-for="EndDate" class="form-control" type="datetime-local" required>
                            </div>
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 justify-content-end form-section">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
        <button type="submit" class="btn btn-success">
            <i class="fas fa-check"></i> Create Session
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
