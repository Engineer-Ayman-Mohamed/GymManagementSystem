@model IReadOnlyList<SessionDto>

@{
    ViewData["Title"] = "Sessions";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-calendar-alt me-2"></i>Sessions</h2>
        <p class="subtitle">Manage all gym sessions</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <div class="btn-group" role="group">
            <a asp-action="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Session
        </a>
    </div>
</div>

@if (TempData["StatusMessage"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    var now = DateTime.UtcNow;
    var upcomingCount = Model.Count(s => s.StartDate > now);
    var thisWeekCount = Model.Count(s => s.StartDate >= now && s.StartDate <= now.AddDays(7));
    var categoryCount = Model.Select(s => s.CategoryName).Distinct().Count();
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-calendar-alt"></i></div>
        <div class="stat-label">Total Sessions</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-list"></i> All sessions</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-clock"></i></div>
        <div class="stat-label">Upcoming</div>
        <div class="stat-value">@upcomingCount</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Future sessions</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-calendar-week"></i></div>
        <div class="stat-label">This Week</div>
        <div class="stat-value">@thisWeekCount</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Starting soon</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-tags"></i></div>
        <div class="stat-label">Categories</div>
        <div class="stat-value">@categoryCount</div>
        <div class="stat-trend"><i class="fas fa-layer-group"></i> Types</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fas fa-list me-2"></i>All Sessions</span>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm" role="group">
                <a asp-action="ExportExcel" class="btn btn-outline-success" title="Export to Excel">
                    <i class="fas fa-file-excel"></i>
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-danger" title="Export to PDF">
                    <i class="fas fa-file-pdf"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Trainer</th>
                        <th>Category</th>
                        <th>Capacity</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-calendar-alt"></i>
                                    <h4>No sessions yet</h4>
                                    <p>Create your first gym session.</p>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add Session
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var session in Model)
                        {
                            <tr>
                                <td><strong>@session.Description</strong></td>
                                <td>@session.TrainerName</td>
                                <td><span class="status-badge active">@session.CategoryName</span></td>
                                <td>@session.Capacity</td>
                                <td>@session.StartDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@session.EndDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@session.Id" class="btn btn-outline-primary btn-sm" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@session.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@session.Id" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
