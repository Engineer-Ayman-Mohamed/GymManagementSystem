@model IReadOnlyList<TrainerDto>

@{
    ViewData["Title"] = "Trainers";
    var specialtyCount = Model.Select(t => t.Specialty).Distinct().Count();
    var newThisMonth = Model.Count(t => t.HireDate >= DateTime.Now.AddMonths(-1));
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-user-tie me-2"></i>Trainers</h2>
        <p class="subtitle">Manage all gym trainers</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <div class="btn-group" role="group">
            <a asp-action="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Trainer
        </a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-user-tie"></i></div>
        <div class="stat-label">Total Trainers</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-list"></i> All trainers</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-clock"></i></div>
        <div class="stat-label">New This Month</div>
        <div class="stat-value">@newThisMonth</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Recently hired</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-tag"></i></div>
        <div class="stat-label">Specialties</div>
        <div class="stat-value">@specialtyCount</div>
        <div class="stat-trend"><i class="fas fa-layer-group"></i> Areas</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-map-marker-alt"></i></div>
        <div class="stat-label">Cities</div>
        <div class="stat-value">@Model.Select(t => t.City).Distinct().Count()</div>
        <div class="stat-trend"><i class="fas fa-building"></i> Locations</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fas fa-list me-2"></i>All Trainers</span>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm" role="group">
                <a asp-action="ExportExcel" class="btn btn-outline-success" title="Export to Excel">
                    <i class="fas fa-file-excel"></i>
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-danger" title="Export to PDF">
                    <i class="fas fa-file-pdf"></i>
                </a>
            </div>
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" class="form-control form-control-sm" id="trainerSearch" placeholder="Search trainers..." style="width: 180px;">
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0" id="trainersTable">
                <thead>
                    <tr>
                        <th>Trainer</th>
                        <th>Contact</th>
                        <th>Specialty</th>
                        <th>Gender</th>
                        <th>Hire Date</th>
                        <th>City</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-user-tie"></i>
                                    <h4>No trainers yet</h4>
                                    <p>Get started by adding your first trainer.</p>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add First Trainer
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var trainer = Model[i];
                            var initial = trainer.Name?.Length > 0 ? trainer.Name[0].ToString().ToUpper() : "?";
                            var isFemale = trainer.Gender == "Female";
                            <tr class="row-striped" style="animation: fadeInUp 0.4s ease-out @(i * 0.05)s both;">
                                <td>
                                    <div class="member-cell">
                                        <div class="member-avatar @(isFemale ? "female" : "")">@initial</div>
                                        <div class="member-info">
                                            <div class="member-name">@trainer.Name</div>
                                            <div class="member-email">@@@trainer.Name?.ToLower().Replace(" ", "")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div><i class="fas fa-envelope text-primary me-1" style="width:14px;"></i>@trainer.Email</div>
                                    <div><i class="fas fa-phone text-success me-1" style="width:14px;"></i>@trainer.Phone</div>
                                </td>
                                <td><span class="status-badge active"><span class="status-dot"></span>@trainer.Specialty</span></td>
                                <td>
                                    <span class="status-badge @(isFemale ? "active" : "inactive")">
                                        <span class="status-dot"></span> @trainer.Gender
                                    </span>
                                </td>
                                <td>@trainer.HireDate.ToString("MMM dd, yyyy")</td>
                                <td><i class="fas fa-map-marker-alt text-danger me-1"></i>@trainer.City</td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@trainer.Id" class="btn btn-outline-primary btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@trainer.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@trainer.Id" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $('#trainerSearch').on('keyup', function() {
                const value = this.value.toLowerCase();
                $('#trainersTable tbody tr').each(function() {
                    const row = $(this);
                    if (row.find('.empty-state').length) return;
                    const text = row.text().toLowerCase();
                    row.toggle(text.includes(value));
                });
            });
        });
    </script>
}
