@model IReadOnlyList<BookingDto>

@{
    ViewData["Title"] = "Bookings";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-bookmark me-2"></i>Bookings</h2>
        <p class="subtitle">Manage all session bookings</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <div class="btn-group" role="group">
            <a asp-action="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Booking
        </a>
    </div>
</div>

@if (TempData["StatusMessage"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    var checkedInCount = Model.Count(b => b.IsAttended);
    var pendingCount = Model.Count(b => !b.IsAttended);
    var thisMonthCount = Model.Count(b => b.BookingDate >= DateTime.Now.AddMonths(-1));
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-bookmark"></i></div>
        <div class="stat-label">Total Bookings</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-list"></i> All bookings</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div class="stat-label">Checked In</div>
        <div class="stat-value">@checkedInCount</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Attended</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-clock"></i></div>
        <div class="stat-label">Pending</div>
        <div class="stat-value">@pendingCount</div>
        <div class="stat-trend"><i class="fas fa-hourglass-half"></i> Awaiting check-in</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-calendar-check"></i></div>
        <div class="stat-label">This Month</div>
        <div class="stat-value">@thisMonthCount</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Recent bookings</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fas fa-list me-2"></i>All Bookings</span>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm" role="group">
                <a asp-action="ExportExcel" class="btn btn-outline-success" title="Export to Excel">
                    <i class="fas fa-file-excel"></i>
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-danger" title="Export to PDF">
                    <i class="fas fa-file-pdf"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Session</th>
                        <th>Trainer</th>
                        <th>Category</th>
                        <th>Booking Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-bookmark"></i>
                                    <h4>No bookings yet</h4>
                                    <p>Create your first booking.</p>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add Booking
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var booking in Model)
                        {
                            var attended = booking.IsAttended;
                            <tr>
                                <td>
                                    <div class="member-cell">
                                        <div class="member-avatar">@(booking.MemberName?.Length > 0 ? booking.MemberName[0].ToString().ToUpper() : "?")</div>
                                        <div class="member-info">
                                            <div class="member-name">@booking.MemberName</div>
                                            <div class="member-email">@booking.MemberEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td><strong>@booking.SessionDescription</strong></td>
                                <td>@booking.TrainerName</td>
                                <td><span class="status-badge active">@booking.CategoryName</span></td>
                                <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (attended)
                                    {
                                        <span class="status-badge active">
                                            <span class="status-dot"></span> Checked In
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge inactive">
                                            <span class="status-dot"></span> Pending
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-controller="Attendance" asp-action="MyQr" asp-route-bookingId="@booking.Id" class="btn btn-outline-dark btn-sm" title="Show QR Code">
                                            <i class="fas fa-qrcode"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-outline-primary btn-sm" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@booking.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
