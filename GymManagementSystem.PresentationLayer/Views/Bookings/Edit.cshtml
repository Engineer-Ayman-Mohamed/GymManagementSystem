@model UpdateBookingRequest

@{
    ViewData["Title"] = "Edit Booking";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-bookmark-edit me-2"></i>Edit Booking</h2>
        <p class="subtitle">Update booking information</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<form asp-action="Edit" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-1"></i>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="small">@error.ErrorMessage</div>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card form-section">
                <div class="card-header">
                    <i class="fas fa-info-circle me-2"></i>Booking Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="MemberId" class="form-label">Member ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input asp-for="MemberId" class="form-control" type="number" placeholder="1">
                            </div>
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SessionId" class="form-label">Session ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                <input asp-for="SessionId" class="form-control" type="number" placeholder="1">
                            </div>
                            <span asp-validation-for="SessionId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BookingDate" class="form-label">Booking Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                <input asp-for="BookingDate" class="form-control" type="date">
                            </div>
                            <span asp-validation-for="BookingDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsAttended" class="form-label">Attended</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                                <select asp-for="IsAttended" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option value="true">Yes</option>
                                    <option value="false">No</option>
                                </select>
                            </div>
                            <span asp-validation-for="IsAttended" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 justify-content-end form-section">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
