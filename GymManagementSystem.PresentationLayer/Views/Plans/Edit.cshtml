@model UpdatePlanRequest

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-edit me-2"></i>Edit Plan</h2>
        <p class="subtitle">Update plan information</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<form asp-action="Edit" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 10px; border-left: 4px solid var(--danger);">
            <i class="fas fa-exclamation-circle" style="font-size: 1.3rem;"></i>
            <div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="small">@error.ErrorMessage</div>
                }
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card form-section">
                <div class="card-header">
                    <i class="fas fa-info-circle me-2"></i>Plan Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Plan Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="e.g. Gold Membership">
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-align-left"></i></span>
                                <textarea asp-for="Description" class="form-control" placeholder="Describe what this plan includes..." rows="4"></textarea>
                            </div>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DurationDays" class="form-label">Duration (Days)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                <input asp-for="DurationDays" class="form-control" type="number" min="1" placeholder="30">
                            </div>
                            <span asp-validation-for="DurationDays" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Price ($)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="29.99">
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">Active (available for purchase)</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card form-section">
                <div class="card-body text-center">
                    <i class="fas fa-sync-alt" style="font-size: 2rem; color: var(--secondary); opacity: 0.5; margin-bottom: 8px;"></i>
                    <p class="small text-muted mb-0">Update the plan details above</p>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 justify-content-end form-section">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
