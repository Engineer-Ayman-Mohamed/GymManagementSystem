@{
    ViewData["Title"] = "My QR Code";
    var qrImage = ViewBag.QrImage as string;
    var bookingId = (int)ViewBag.BookingId;
    var payload = ViewBag.Payload as string;
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-qrcode me-2"></i>My QR Code</h2>
        <p class="subtitle">Show this code at the gym entrance to check in</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card text-center">
            <div class="card-header">
                <i class="fas fa-ticket-alt me-2"></i>Booking @bookingId
            </div>
            <div class="card-body py-5">
                <div class="qr-container mb-4" style="display:inline-block; padding: 20px; background: white; border-radius: var(--border-radius); box-shadow: var(--shadow);">
                    <img src="data:image/png;base64,@qrImage" alt="QR Code" style="width: 220px; height: 220px; image-rendering: pixelated;" />
                </div>
                <p class="text-muted small mb-3">
                    <i class="fas fa-info-circle me-1"></i>Present this QR code at the front desk for quick check-in
                </p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a href="data:image/png;base64,@qrImage" download="booking-@bookingId-qr.png" class="btn btn-primary">
                        <i class="fas fa-download"></i> Download QR
                    </a>
                    <a asp-action="Scan" class="btn btn-outline-success">
                        <i class="fas fa-camera"></i> Scan QR
                    </a>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>QR Details
            </div>
            <div class="card-body">
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-hashtag"></i> Booking ID</span>
                    <span class="detail-value">@bookingId</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-qrcode"></i> Payload</span>
                    <span class="detail-value" style="font-size:0.75rem; max-width: 280px; word-break: break-all;">@payload</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-clock"></i> Generated</span>
                    <span class="detail-value">@DateTime.Now.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            </div>
        </div>
    </div>
</div>
