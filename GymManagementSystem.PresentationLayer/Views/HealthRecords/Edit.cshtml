@model UpdateHealthRecordRequest

@{
    ViewData["Title"] = "Edit Health Record";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-edit me-2"></i>Edit Health Record</h2>
        <p class="subtitle">Update health information for @ViewBag.MemberName</p>
    </div>
    <a asp-controller="Members" asp-action="Details" asp-route-id="@ViewBag.MemberId" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to Member
    </a>
</div>

<form asp-action="Edit" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 10px; border-left: 4px solid var(--danger);">
            <i class="fas fa-exclamation-circle" style="font-size: 1.3rem;"></i>
            <div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="small">@error.ErrorMessage</div>
                }
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card form-section">
                <div class="card-header">
                    <i class="fas fa-heartbeat me-2"></i>Health Details
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Height" class="form-label">Height (cm)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-ruler-vertical"></i></span>
                                <input asp-for="Height" class="form-control" type="number" step="0.1" min="0" placeholder="e.g. 175.0">
                            </div>
                            <span asp-validation-for="Height" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Weight" class="form-label">Weight (kg)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-weight"></i></span>
                                <input asp-for="Weight" class="form-control" type="number" step="0.1" min="0" placeholder="e.g. 70.5">
                            </div>
                            <span asp-validation-for="Weight" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BloodType" class="form-label">Blood Type</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tint"></i></span>
                                <select asp-for="BloodType" class="form-select">
                                    <option value="">-- Select Blood Type --</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                </select>
                            </div>
                            <span asp-validation-for="BloodType" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Note" class="form-label">Notes (optional)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-sticky-note"></i></span>
                                <textarea asp-for="Note" class="form-control" placeholder="Any additional health notes..." rows="3" maxlength="500"></textarea>
                            </div>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card form-section">
                <div class="card-body text-center">
                    <i class="fas fa-sync-alt" style="font-size: 2rem; color: var(--secondary); opacity: 0.5; margin-bottom: 8px;"></i>
                    <p class="small text-muted mb-0">Update the health details above</p>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4 justify-content-end form-section">
        <a asp-controller="Members" asp-action="Details" asp-route-id="@ViewBag.MemberId" class="btn btn-outline-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
