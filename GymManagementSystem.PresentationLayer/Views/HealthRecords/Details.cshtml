@model HealthRecordDto

@{
    ViewData["Title"] = "Health Record Details";
    var bmi = Model.Height > 0 ? Model.Weight / ((Model.Height / 100m) * (Model.Height / 100m)) : 0;
    var bmiClass = bmi < 18.5m ? "inactive" : bmi < 25m ? "active" : "pending";
    var bmiLabel = bmi < 18.5m ? "Underweight" : bmi < 25m ? "Normal" : bmi < 30m ? "Overweight" : "Obese";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-heartbeat me-2"></i>Health Record</h2>
        <p class="subtitle">Health details for @Model.MemberName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-controller="Members" asp-action="Details" asp-route-id="@Model.MemberId" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left"></i> Back to Member
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="profile-header">
            <div class="profile-avatar-lg">
                <i class="fas fa-heartbeat"></i>
            </div>
            <h3>@Model.MemberName</h3>
            <p><i class="fas fa-id me-1"></i>Member ID: @Model.MemberId</p>
            <span class="status-badge @bmiClass">
                <span class="status-dot"></span>
                BMI: @bmi.ToString("F1") - @bmiLabel
            </span>
        </div>
    </div>

    <div class="col-lg-8 d-flex flex-column gap-3">
        <div class="card detail-group">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Health Information
            </div>
            <div class="card-body">
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-user"></i> Member</span>
                    <span class="detail-value">@Model.MemberName</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-ruler-vertical"></i> Height</span>
                    <span class="detail-value">@Model.Height.ToString("F1") cm</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-weight"></i> Weight</span>
                    <span class="detail-value">@Model.Weight.ToString("F1") kg</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-calculator"></i> BMI</span>
                    <span class="detail-value">
                        <span class="status-badge @bmiClass">
                            <span class="status-dot"></span>
                            @bmi.ToString("F1") - @bmiLabel
                        </span>
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-tint"></i> Blood Type</span>
                    <span class="detail-value"><strong>@Model.BloodType</strong></span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-sticky-note"></i> Notes</span>
                    <span class="detail-value">@(string.IsNullOrEmpty(Model.Note) ? "No additional notes" : Model.Note)</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-clock"></i> Created At</span>
                    <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
        </div>
    </div>
</div>
