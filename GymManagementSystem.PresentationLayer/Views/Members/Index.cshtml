@model IReadOnlyList<MemberDto>

@{
    ViewData["Title"] = "Members";
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-users me-2"></i>Members</h2>
        <p class="subtitle">Manage all gym members</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <div class="btn-group" role="group">
            <a asp-action="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-danger">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Member
        </a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-users"></i></div>
        <div class="stat-label">Total Members</div>
        <div class="stat-value" id="totalCount">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Active members</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-user-plus"></i></div>
        <div class="stat-label">New This Month</div>
        <div class="stat-value" id="newThisMonth">@Model.Count(m => m.JoinDate >= DateTime.Now.AddMonths(-1))</div>
        <div class="stat-trend"><i class="fas fa-arrow-up"></i> Since last month</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-calendar-check"></i></div>
        <div class="stat-label">Active Memberships</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-trend"><i class="fas fa-check-circle"></i> Verified</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-map-marker-alt"></i></div>
        <div class="stat-label">Cities</div>
        <div class="stat-value">@Model.Select(m => m.City).Distinct().Count()</div>
        <div class="stat-trend"><i class="fas fa-building"></i> Locations</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="fas fa-list me-2"></i>All Members</span>
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm" role="group">
                <a asp-action="ExportExcel" class="btn btn-outline-success" title="Export to Excel">
                    <i class="fas fa-file-excel"></i>
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-danger" title="Export to PDF">
                    <i class="fas fa-file-pdf"></i>
                </a>
            </div>
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" class="form-control form-control-sm" id="memberSearch" placeholder="Search members..." style="width: 180px;">
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover mb-0" id="membersTable">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Contact</th>
                        <th>Gender</th>
                        <th>Date of Birth</th>
                        <th>City</th>
                        <th>Join Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-users"></i>
                                    <h4>No members yet</h4>
                                    <p>Get started by adding your first member.</p>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add First Member
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var member = Model[i];
                            var initial = member.Name?.Length > 0 ? member.Name[0].ToString().ToUpper() : "?";
                            var isFemale = member.Gender == "Female";
                            <tr class="row-striped" style="animation: fadeInUp 0.4s ease-out @(i * 0.05)s both;">
                                <td>
                                    <div class="member-cell">
                                        <div class="member-avatar @(isFemale ? "female" : "")">@initial</div>
                                        <div class="member-info">
                                            <div class="member-name">@member.Name</div>
                                            <div class="member-email">@@@member.Name?.ToLower().Replace(" ", "")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div><i class="fas fa-envelope text-primary me-1" style="width:14px;"></i>@member.Email</div>
                                    <div><i class="fas fa-phone text-success me-1" style="width:14px;"></i>@member.Phone</div>
                                </td>
                                <td>
                                    <span class="status-badge @(isFemale ? "active" : "inactive")">
                                        <span class="status-dot"></span>
                                        @member.Gender
                                    </span>
                                </td>
                                <td>@member.DateOfBirth.ToString("MMM dd, yyyy")</td>
                                <td><i class="fas fa-map-marker-alt text-danger me-1"></i>@member.City</td>
                                <td>@member.JoinDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-outline-primary btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@member.Id" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $('#memberSearch').on('keyup', function() {
                const value = this.value.toLowerCase();
                $('#membersTable tbody tr').each(function() {
                    const row = $(this);
                    if (row.find('.empty-state').length) return;
                    const text = row.text().toLowerCase();
                    row.toggle(text.includes(value));
                });
            });

            if ($('#statusToast').length) {
                setTimeout(function() { $('#statusToast').toast('hide'); }, 4000);
            }
        });
    </script>
}
